# ============================================================
# .env.example — Variables d'environnement Portfolio HPB
#
# EN LOCAL  : copiez en .env et remplissez les valeurs
# SUR RENDER: configurez dans Dashboard → Environment
# ============================================================

# ── OBLIGATOIRES ─────────────────────────────────────────────

# Clé secrète Django — générez-en une unique :
# python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
SECRET_KEY=remplacez-par-une-vraie-cle-aleatoire-longue

# Hosts autorisés (votre URL Render)
ALLOWED_HOSTS=hillaprince.onrender.com

# Injectée automatiquement par Render si vous ajoutez une PostgreSQL DB
# DATABASE_URL=postgresql://user:password@host:5432/dbname

# ── ADMIN DJANGO ─────────────────────────────────────────────
DJANGO_SUPERUSER_USERNAME=hillaprince
DJANGO_SUPERUSER_EMAIL=hillaprincebambe@gmail.com
DJANGO_SUPERUSER_PASSWORD=UnMotDePasseAuMoins12Caracteres!

# ── OPTIONNELS ───────────────────────────────────────────────

# Niveau de logs (DEBUG, INFO, WARNING, ERROR)
DJANGO_LOG_LEVEL=WARNING

# ============================================================
# SÉCURITÉ — Ne jamais committer le vrai .env dans Git !
# Ajoutez .env dans .gitignore
# ============================================================
